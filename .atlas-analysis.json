  "keyFeatures": [
    "Role-based access control with four roles: admin, cajero, mesero, cocina",
    "Full order lifecycle management from creation to payment",
    "Table management with real-time status tracking (libre, ocupada, mantenimiento)",
    "Reservation system with online public booking endpoint",
    "Menu management with category support and ImageKit image uploads",
    "Payment processing supporting efectivo, tarjeta, QR, and transferencia",
    "Automatic ticket and invoice (factura) generation on payment",
    "PDF report generation for 10 report types including daily sales and cash close",
    "Dashboard with Chart.js sales analytics (weekly/monthly trends, top products)",
    "Audit logging of all significant actions with user, action, and IP"
  ],
